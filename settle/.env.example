# AWS Configuration
AWS_REGION=eu-west-1

# VPC Configuration
VPC_CIDR=117.0.0.0/16

# RDS Configuration
DB_USERNAME=settle_admin
DB_PASSWORD=password123
DB_NAME=settle_db
DB_INSTANCE_CLASS=db.t4g.micro
DB_ALLOCATED_STORAGE=20

# S3 Bucket ARNs (pre-existing)
INCOMING_SETTLEMENT_DATA_ARN=arn:aws:s3:::incoming-settlement-data
NORMALIZED_SETTLEMENT_DATA_ARN=arn:aws:s3:::normalized-settlement-data

# Big-data buckets (output of settle-big-data-buckets stack — run that first)
RAW_BUCKET_NAME=
RAW_BUCKET_ARN=
CLEAN_BUCKET_NAME=
CLEAN_BUCKET_ARN=

# Lambda Code Paths (relative to workspace root)
SEED_LAMBDA_CODE_PATH=../../dist/apps/settle-ingest-lambda
TRANSFORM_LAMBDA_CODE_PATH=../../dist/apps/settle-transform-lambda

# Pulumi Stack References (used by Unit 2 & 3)
INFRA_STACK_NAME=settle-infra/dev
